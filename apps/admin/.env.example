# Ekler Admin panel — required environment.
# Copy to apps/admin/.env (gitignored) and fill in. The panel REFUSES to boot if
# any of ADMIN_EMAIL / ADMIN_PASSWORD / ADMIN_COOKIE_SECRET is unset or empty —
# there are no baked-in defaults (a known password + forgeable cookie secret
# would be an auth bypass).

# Postgres connection (txn pooler — the panel opens several pools incl. a ban txn).
DATABASE_URL=postgresql://user:pass@host:6543/postgres

# Single-admin login (RBAC via admin_identities is a later phase).
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-to-a-strong-password

# Session/cookie signing key — generate ≥32 random bytes, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ADMIN_COOKIE_SECRET=

# Optional.
ADMIN_PORT=3020

# Only needed while images live in Supabase Storage (show-screen signing).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
