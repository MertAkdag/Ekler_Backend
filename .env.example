# ─── ekler-backend env (copy to apps/api/.env for local dev) ─────────────────
# NEVER commit real values. Phase 0 only needs DATABASE_URL + SUPABASE_* for the
# auth bridge; the rest land in their phases.

NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# ─── Postgres ────────────────────────────────────────────────────────────────
# Phase 0–6: Supabase Postgres via the SESSION-mode pooler (port 5432), NOT the
# transaction pooler (6543) — txn mode breaks prepared statements, SET LOCAL,
# advisory locks and our multi-statement FOR UPDATE transactions.
# Phase 7+: swap to the Neon pooled connection string, same variable.
DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
# Direct connection (no pooler) — used ONLY by drizzle-kit pull / migrations.
DIRECT_DATABASE_URL=postgresql://postgres.<ref>:<password>@db.<ref>.supabase.co:5432/postgres
PG_POOL_MAX=10

# ─── Auth bridge (Phase 1) ───────────────────────────────────────────────────
# Verify Supabase-issued JWTs against the project JWKS during the dual-accept window.
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_JWKS_URL=https://<ref>.supabase.co/auth/v1/.well-known/jwks.json
# Legacy HS256 fallback (older Supabase projects sign with the JWT secret, not JWKS).
SUPABASE_JWT_SECRET=
# Service-role key — server-only, used for storage/admin RPC during transition. NEVER ship to client.
SUPABASE_SERVICE_ROLE_KEY=

# ─── Own auth (Phase 8) ──────────────────────────────────────────────────────
# Dual-accept toggle / server kill switch: 'dual' (own + Supabase) | 'own_only'.
# Keep 'dual' until the client cutover is live; flip back to 'dual' to roll back.
AUTH_MODE=dual
# Ed25519 keypair (PEM). Generate: see README "Auth keys".
AUTH_JWT_PRIVATE_KEY=
AUTH_JWT_PUBLIC_KEY=
# kid stamped in our token headers + published in the JWKS.
AUTH_JWT_KID=ek-ed25519-1
# Optional rotation overlap: keep the PREVIOUS public key verify-only (sign with the
# new one above) until old tokens expire. Set both or neither.
AUTH_JWT_PUBLIC_KEY_PREV=
AUTH_JWT_KID_PREV=
AUTH_OTP_PEPPER=
AUTH_ACCESS_TTL=900
AUTH_REFRESH_TTL=2592000
# Absolute refresh-family lifetime (s). A rotating/stolen chain dies this long after
# first issue regardless of per-token TTL. Default 90d.
AUTH_FAMILY_TTL=7776000

# ─── Redis (Upstash) — BullMQ + throttler + presence ─────────────────────────
REDIS_URL=

# ─── Object storage (Phase 4) — provider-neutral S3 API ──────────────────────
# Self-hosted MinIO on our VPS (default plan), or Cloudflare R2 / AWS S3 — only
# these values change, the code is identical.
#   MinIO:  STORAGE_ENDPOINT=https://storage.<domain>  + STORAGE_FORCE_PATH_STYLE=true
#   R2:     STORAGE_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
STORAGE_ENDPOINT=
STORAGE_REGION=auto
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_FORCE_PATH_STYLE=true
# Public base for the un-signed (communities) bucket reads.
STORAGE_PUBLIC_URL=
STORAGE_BUCKET_CONFESSIONS=ekler-confessions
STORAGE_BUCKET_NOTES=ekler-notes
STORAGE_BUCKET_COMMUNITIES=ekler-communities
STORAGE_SIGN_TTL=3600
STORAGE_UPLOAD_MAX_BYTES=20971520

# ─── Email (Resend, Phase 8 OTP) ─────────────────────────────────────────────
RESEND_API_KEY=
OTP_FROM_EMAIL=giris@ekler.app

# ─── Push (Phase 5) ──────────────────────────────────────────────────────────
EXPO_ACCESS_TOKEN=

# ─── Observability ───────────────────────────────────────────────────────────
SENTRY_DSN=
