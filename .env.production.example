# EKLER production env — copy to `.env` next to docker-compose.yml and fill in.
# NEVER commit the real .env. CHANGE every CHANGE_ME below.

# ── Postgres + MinIO passwords (read by docker-compose interpolation) ────────
POSTGRES_PASSWORD=CHANGE_ME_long_random
MINIO_ROOT_USER=eklerstorage
MINIO_ROOT_PASSWORD=CHANGE_ME_long_random

# ── API runtime ──────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3010
ADMIN_PORT=3020
# host = the compose service name `postgres`; password MUST match POSTGRES_PASSWORD above.
DATABASE_URL=postgresql://postgres:CHANGE_ME_long_random@postgres:5432/ekler
# own_only = accept ONLY our own EdDSA tokens (no Supabase). Correct for a fresh server.
AUTH_MODE=own_only

# Own-auth signing keys (Ed25519). Generate them — see deploy/DEPLOY.md step 4.
# Paste the PEM as a single line with literal \n between lines, in quotes.
AUTH_JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
AUTH_JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----\n"
AUTH_JWT_KID=ek-ed25519-1
AUTH_OTP_PEPPER=CHANGE_ME_long_random

# ── Login emails (OTP) — REQUIRED, else no one can log in ────────────────────
# Resend (resend.com): create a key, verify the ekler.app domain for sending.
RESEND_API_KEY=re_CHANGE_ME
OTP_EMAIL_FROM=EKLER <giris@ekler.app>

# ── Object storage (MinIO behind storage.ekler.app) ──────────────────────────
# Public URL so the SIGNED upload/read URLs the API returns are reachable by phones.
STORAGE_ENDPOINT=https://storage.ekler.app
STORAGE_REGION=auto
STORAGE_ACCESS_KEY_ID=eklerstorage          # = MINIO_ROOT_USER (or a dedicated MinIO key)
STORAGE_SECRET_ACCESS_KEY=CHANGE_ME_long_random  # = MINIO_ROOT_PASSWORD
STORAGE_FORCE_PATH_STYLE=true
STORAGE_PUBLIC_URL=https://storage.ekler.app/ekler-communities
STORAGE_BUCKET_CONFESSIONS=ekler-confessions
STORAGE_BUCKET_NOTES=ekler-notes
STORAGE_BUCKET_COMMUNITIES=ekler-communities

# ── Admin panel (admin.ekler.app) ────────────────────────────────────────────
ADMIN_EMAIL=sen@ekler.app
ADMIN_PASSWORD=CHANGE_ME_long_random
ADMIN_COOKIE_SECRET=CHANGE_ME_32_chars_min_random
ADMIN_DB_NAME=ekler

# No SUPABASE_* vars are needed: AUTH_MODE=own_only + storage on MinIO = zero Supabase.
